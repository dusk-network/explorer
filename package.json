{
	"name": "explorer",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build": "vite build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"dev": "vite dev",
		"lint": "npm run lint:tests && npm run lint:code",
		"lint:code": "eslint . -c .eslintrc.cjs",
		"lint:tests": "eslint . -c .eslintrc.tests.cjs",
		"preview": "vite preview",
		"test": "vitest --run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@dusk-network/eslint-config": "2.0.0",
		"@sveltejs/adapter-static": "^2.0.3",
		"@sveltejs/kit": "1.25.1",
		"autoprefixer": "10.4.16",
		"eslint": "8.50.0",
		"eslint-import-resolver-custom-alias": "1.3.2",
		"eslint-plugin-import": "2.28.1",
		"eslint-plugin-svelte": "2.33.2",
		"postcss": "8.4.31",
		"svelte": "4.2.1",
		"svelte-check": "3.5.2",
		"tailwindcss": "3.3.3",
		"typescript": "5.2.2",
		"vite": "4.4.10",
		"vitest": "0.34.6"
	},
	"type": "module"
}
